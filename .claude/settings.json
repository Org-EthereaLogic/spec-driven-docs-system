{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "(Write|Edit).*(spec_driven_docs|app_docs|docs)/.*\\.md$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/doc_pre_write.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "(Write|Edit).*(spec_driven_docs|app_docs|docs)/.*\\.md$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/doc_post_write.py"
          }
        ]
      },
      {
        "matcher": "SlashCommand.*/doc-review.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/doc_post_review.py"
          }
        ]
      }
    ]
  }
}
