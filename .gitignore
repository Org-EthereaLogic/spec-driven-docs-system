# =============================================================================
# Project-Specific
# =============================================================================

# Generated documentation (uncomment to exclude from version control)
# docs/

# =============================================================================
# Test Artifacts
# =============================================================================

# Test suite manifests (keep _example as template)
.claude/docs/suites/*
!.claude/docs/suites/_example/
!.claude/docs/suites/README.md

# Test spec files (keep _example as template)
specs/docs/*
!specs/docs/_example/
!specs/docs/README.md

# Project-specific deliverable bundles (customer hand-off packages produced
# by the framework). Like specs/docs/* and .claude/docs/suites/*, these
# contain content that pertains to specific projects and should not be
# tracked by the public framework repo.
deliverables/

# Project-specific generated documentation (per-project workflow output).
# The rough_draft / pending_approval / approved_final directories carry
# README.md files that describe the workflow stage (those stay tracked);
# every other artifact is project content and stays local.
spec_driven_docs/rough_draft/*
spec_driven_docs/pending_approval/*
spec_driven_docs/approved_final/*
!spec_driven_docs/rough_draft/README.md
!spec_driven_docs/pending_approval/README.md
!spec_driven_docs/approved_final/README.md

# Test archives (local only, not committed)
tests/archives/

# Prompt drafts (working files, not final)
prompt/draft/
prompt/enhanced/

# VSCode AI instructions (auto-generated)
.github/instructions/codacy.instructions.md

# Empty placeholder directories (keep .gitkeep files if present)
chat/
.chat/testing-notes.md

# Snyk Security Extension - AI Rules (auto-generated)
.github/instructions/snyk_rules.instructions.md

# External agent-platform artifacts (auto-generated, machine-specific).
# Codex CLI config mirrors .claude/ with hardcoded absolute paths, and the
# migrated skill files carry templated cross-project references. Regenerate
# locally as needed; not portable repo content.
.codex/
.agents/
